<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.caicai.swe.mapper.CategoryMapper">

    <resultMap id="BaseResultMap" type="com.caicai.swe.entity.Category">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="parent_id" property="parentId"/>
        <result column="sort" property="sort"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <resultMap id="VOResultMap" type="com.caicai.swe.vo.CategoryVO">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="parent_id" property="parentId"/>
        <result column="sort" property="sort"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectAll" resultMap="VOResultMap">
        SELECT * FROM category ORDER BY sort ASC, id ASC
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM category WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.caicai.swe.entity.Category" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO category (name, parent_id, sort)
        VALUES (#{name}, #{parentId}, #{sort})
    </insert>

    <update id="update" parameterType="com.caicai.swe.entity.Category">
        UPDATE category
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="sort != null">sort = #{sort},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM category WHERE id = #{id}
    </delete>

</mapper>